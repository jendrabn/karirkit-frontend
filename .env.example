# API Configuration
VITE_APP_API_URL=http://localhost:3000

# Enable API Mocking (true/false)
VITE_APP_ENABLE_API_MOCKING=false

# Application URL
VITE_APP_URL=http://localhost:3000

# Enable Debug Mode (true/false)
VITE_APP_DEBUG=true

# Mock API Port (used when ENABLE_API_MOCKING is true)
VITE_APP_MOCK_API_PORT=8080

VITE_APP_GOOGLE_CLIENT_ID=your_google_client_id

VITE_APP_MIDTRANS_CLIENT_KEY=your_midtrans_client_key

VITE_APP_NAME=KarirKit

VITE_APP_SUPPORT_EMAIL=support@karirkit.com
